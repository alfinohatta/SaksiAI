<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:id="@+id/layout_rel_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_rel_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_share"
            app:tint="#666666" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_rel_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRADICTS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:textColor="#D32F2F"/>

            <TextView
                android:id="@+id/tv_target_entity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historical Identity Record"
                android:textColor="#333333"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_rel_confidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="99% AI Conf."
            android:textColor="#666666"
            android:textSize="11sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>