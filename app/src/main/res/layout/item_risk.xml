<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FFCDD2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_risk_severity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#B71C1C"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:text="HIGH"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_risk_type"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="FRAUD DETECTION"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_risk_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score: 88.5"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_risk_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Explanation of the risk detected by SaksiAI engine."
            android:textColor="#666666"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>