<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">
        <View
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@android:drawable/presence_online"
            android:backgroundTint="#2196F3" />
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="#E0E0E0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_log_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI_DECISION_PATH"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_log_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2023-10-27 14:30:01"
            android:textColor="#999999"
            android:textSize="11sp" />

        <!-- AI Safety Framework: Explainable Reasoning Path -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F0F7FF"
            app:strokeWidth="1dp"
            app:strokeColor="#BBDEFB">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DECISION REASONING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"/>

                <TextView
                    android:id="@+id/tv_reasoning_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting for AI reasoning..."
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_transaction_hash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TX: 0x882...f31"
            android:textColor="#BDBDBD"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</LinearLayout>